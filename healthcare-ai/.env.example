# ── Tammeny — Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# Mistral AI (for chatbot & RAG)
# Get from: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_key_here

# HuggingFace (for embeddings)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=your_hf_token_here

# HuggingFace Router (for Vision AI / Live_MedProc)
# Same token works — paste it here too
HF_ROUTER_TOKEN=your_hf_token_here

# Optional: Ollama web search (for main.py)
OLLAMA_API_KEY=your_ollama_key_here

# Server settings (optional)
HOST=127.0.0.1
PORT=8000
